# ─────────────────────────────────────────────────────────────────────────────
# Modèle de configuration — COPIER vers .env puis renseigner les valeurs.
#   cp .env.example .env   (Linux/Mac)   |   copy .env.example .env   (Windows)
#
# Le vrai fichier .env n'est JAMAIS versionné (présent dans .gitignore) :
# il contient des secrets (clé API).
# ─────────────────────────────────────────────────────────────────────────────

# Clé de l'API Mistral — à créer sur https://console.mistral.ai
# (génération des réponses du RAG)
MISTRAL_API_KEY=votre_cle_mistral_ici

# Modèle de génération sur la plateforme Mistral
MISTRAL_MODEL=mistral-small-latest

# Clé protégeant l'endpoint POST /rebuild (header X-API-Key)
# À changer pour toute utilisation réelle
API_KEY=changez_cette_valeur

# Modèle d'embedding (doit correspondre à celui ayant servi à build_index.py)
SBERT_MODEL=paraphrase-multilingual-mpnet-base-v2

# Emplacements des données et de l'index (valeurs par défaut adaptées au repo)
FAISS_INDEX_PATH=data/faiss_index
CLEAN_DATA_PATH=data/processed/evenements_idf_clean.json
